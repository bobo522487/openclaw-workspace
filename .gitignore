# OpenClaw Git Ignore
# ===================

# Sensitive data
*.token
ha_token.txt
medication-state.json
openclaw.json
openclaw.json.backup

# Credentials
credentials/
*.secret
*.key
*.pem

# Environment
.env
.env.local

# Node modules
node_modules/
.pnpm-store/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv

# Temporary files
*.tmp
*.temp
*.log
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Build artifacts
dist/
build/
*.o
*.a

# Session data (may contain sensitive info)
sessions/
*.session
*.db

# State directories that shouldn't be versioned
agents/
browser/

# Workspace duplicates - files in root should be versioned, not in workspace/ subdirs
/workspace/AGENTS.md
/workspace/SOUL.md
/workspace/IDENTITY.md
/workspace/USER.md
/workspace/TOOLS.md
